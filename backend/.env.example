# Runtime
ENVIRONMENT=development
FRONTEND_ORIGIN=http://127.0.0.1:8000
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Supabase
# Choose one server-side key style after checking the Supabase dashboard.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Legacy fallback only. Remove after the key naming migration is complete.
SUPABASE_KEY=

# Firebase Auth
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_MEASUREMENT_ID=

# Optional custom transactional email provider for account recovery notices.
BREVO_API_KEY=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=VeilPlays
MAIL_ASSET_BASE_URL=

# Initial administrator bootstrap
SUPER_ADMIN_FIREBASE_UIDS=

# Shared secrets for local tokens and recovery identifier hashing.
# In production, ADMIN_TOKEN_SECRET and BLIND_TOKEN_SECRET must each be at least 32 bytes.
ADMIN_TOKEN_SECRET=
BLIND_TOKEN_SECRET=

# Comma-separated reverse proxy IP addresses or CIDR ranges.
# Forwarded client IP headers are ignored unless the direct peer matches this list.
TRUSTED_PROXY_IPS=

# Backend OAuth providers
OAUTH_STATE_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
# Optional. Required only for Kakao provider unlink/revocation.
KAKAO_ADMIN_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
STEAM_API_KEY=
STEAM_RETURN_URL=
STEAM_REALM=
